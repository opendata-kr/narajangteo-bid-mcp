{
  "name": "bid-public-info-service-mcp",
  "version": "0.0.0",
  "description": "나라장터 입찰공고정보서비스 Open API를 위한 로컬 MCP 서버",
  "type": "module",
  "bin": {
    "bid-public-info-service-mcp": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@11.8.0",
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/index.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "keywords": [
    "mcp",
    "modelcontextprotocol",
    "나라장터",
    "입찰공고",
    "data.go.kr"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@types/node": "latest",
    "tsup": "latest",
    "tsx": "latest",
    "typescript": "latest",
    "vitest": "latest"
  }
}
