{
  "$schema": "https://static.modelcontextprotocol.io/schemas/2025-12-11/server.schema.json",
  "name": "io.github.opendata-kr/narajangteo-bid-mcp",
  "description": "나라장터 입찰공고정보서비스(공공데이터포털 data.go.kr) Open API를 감싼 로컬 MCP 서버",
  "title": "나라장터 입찰공고",
  "websiteUrl": "https://github.com/opendata-kr/narajangteo-bid-mcp#readme",
  "repository": {
    "url": "https://github.com/opendata-kr/narajangteo-bid-mcp",
    "source": "github"
  },
  "version": "0.3.0",
  "packages": [
    {
      "registryType": "npm",
      "registryBaseUrl": "https://registry.npmjs.org",
      "identifier": "@opendata-kr/narajangteo-bid-mcp",
      "version": "0.3.0",
      "transport": {
        "type": "stdio"
      },
      "environmentVariables": [
        {
          "name": "DATA_GO_KR_SERVICE_KEY",
          "description": "공공데이터포털 data.go.kr Decoding(원본) 인증키",
          "isRequired": true,
          "isSecret": true
        },
        {
          "name": "DATA_GO_KR_BASE_URL",
          "description": "게이트웨이 base URL 오버라이드",
          "default": "https://apis.data.go.kr"
        },
        {
          "name": "DATA_GO_KR_DOWNLOAD_DIR",
          "description": "download_attachments 저장 기준 디렉터리. 공고번호별 하위폴더로 저장한다. 미설정 시 ~/Downloads",
          "default": "~/Downloads"
        },
        {
          "name": "DATA_GO_KR_DOWNLOAD_TIMEOUT_MS",
          "description": "download_attachments 파일 다운로드 타임아웃(밀리초)",
          "default": "60000"
        },
        {
          "name": "DATA_GO_KR_DOWNLOAD_MAX_BYTES",
          "description": "download_attachments 파일당 다운로드 크기 상한(바이트, 기본 100MB)",
          "default": "104857600"
        }
      ]
    }
  ]
}
